{
  "name": "Zap Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#1e1e1e",
    "editor.foreground": "#d4d4d4",
    "editor.selectionBackground": "#264f78",
    "editor.lineHighlightBackground": "#2a2a2a",
    "editorCursor.foreground": "#aeafad",
    "activityBar.background": "#333333",
    "activityBar.foreground": "#ffffff",
    "sideBar.background": "#252526",
    "sideBar.foreground": "#cccccc",
    "statusBar.background": "#007acc",
    "statusBar.foreground": "#ffffff",
    "tab.activeBackground": "#1e1e1e",
    "tab.activeForeground": "#ffffff",
    "tab.inactiveBackground": "#2d2d2d",
    "tab.inactiveForeground": "#ffffff80",
    "editorLineNumber.foreground": "#858585",
    "editorLineNumber.activeForeground": "#c6c6c6",
    "editorIndentGuide.background": "#404040",
    "editorBracketMatch.background": "#0d3a58",
    "editorBracketMatch.border": "#888888"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": ["comment.line.zap", "comment.block.zap", "comment"],
      "settings": { "foreground": "#6a9955", "fontStyle": "italic" }
    },
    {
      "name": "Keywords — control flow (if, else, while, loop, return, break, continue, try, catch, from, to, step)",
      "scope": ["keyword.control.zap", "keyword.control"],
      "settings": { "foreground": "#c586c0" }
    },
    {
      "name": "Storage keywords (let, fn)",
      "scope": ["storage.type.zap", "storage.type"],
      "settings": { "foreground": "#569cd6" }
    },
    {
      "name": "Import / export",
      "scope": ["keyword.control.import.zap"],
      "settings": { "foreground": "#c586c0" }
    },
    {
      "name": "Variables declared with let",
      "scope": ["variable.name.zap"],
      "settings": { "foreground": "#9cdcfe" }
    },
    {
      "name": "All other identifiers / variables",
      "scope": ["variable.other.zap", "variable.other", "variable"],
      "settings": { "foreground": "#9cdcfe" }
    },
    {
      "name": "Function declarations",
      "scope": ["entity.name.function.zap", "entity.name.function"],
      "settings": { "foreground": "#dcdcaa" }
    },
    {
      "name": "Function calls",
      "scope": ["entity.name.function.call.zap"],
      "settings": { "foreground": "#dcdcaa" }
    },
    {
      "name": "Function parameters",
      "scope": ["variable.parameter.zap", "variable.parameter"],
      "settings": { "foreground": "#9cdcfe" }
    },
    {
      "name": "Built-in functions (print, len, push, sqrt, etc.)",
      "scope": ["support.function.builtin.zap", "support.function"],
      "settings": { "foreground": "#4ec9b0" }
    },
    {
      "name": "String literals",
      "scope": [
        "string.quoted.double.zap",
        "string.quoted.single.zap",
        "string.quoted.template.zap",
        "string"
      ],
      "settings": { "foreground": "#ce9178" }
    },
    {
      "name": "Template string body",
      "scope": ["string.template.zap"],
      "settings": { "foreground": "#ce9178" }
    },
    {
      "name": "Template expression braces { }",
      "scope": [
        "punctuation.definition.template-expression.zap",
        "meta.template.expression.zap punctuation"
      ],
      "settings": { "foreground": "#569cd6", "fontStyle": "bold" }
    },
    {
      "name": "Template expression content (variables inside { })",
      "scope": ["meta.template.expression.zap"],
      "settings": { "foreground": "#9cdcfe" }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric.zap", "constant.numeric"],
      "settings": { "foreground": "#b5cea8" }
    },
    {
      "name": "Boolean constants (true, false)",
      "scope": [
        "constant.language.boolean.zap",
        "constant.language.true.zap",
        "constant.language.false.zap"
      ],
      "settings": { "foreground": "#569cd6" }
    },
    {
      "name": "Null constant",
      "scope": ["constant.language.null.zap"],
      "settings": { "foreground": "#569cd6" }
    },
    {
      "name": "Escape sequences",
      "scope": ["constant.character.escape.zap"],
      "settings": { "foreground": "#d7ba7d" }
    },
    {
      "name": "Arithmetic operators (+ - * / %)",
      "scope": ["keyword.operator.arithmetic.zap"],
      "settings": { "foreground": "#d4d4d4" }
    },
    {
      "name": "Comparison operators (== != < > <= >=)",
      "scope": ["keyword.operator.comparison.zap"],
      "settings": { "foreground": "#d4d4d4" }
    },
    {
      "name": "Logical operators (&& || !)",
      "scope": ["keyword.operator.logical.zap"],
      "settings": { "foreground": "#d4d4d4" }
    },
    {
      "name": "Assignment operators (= += -= *= /=)",
      "scope": ["keyword.operator.assignment.zap"],
      "settings": { "foreground": "#d4d4d4" }
    },
    {
      "name": "Increment / decrement (++ --)",
      "scope": ["keyword.operator.increment.zap"],
      "settings": { "foreground": "#d4d4d4" }
    },
    {
      "name": "Power operator (**)",
      "scope": ["keyword.operator.power.zap"],
      "settings": { "foreground": "#d4d4d4" }
    },
    {
      "name": "Ternary (?)",
      "scope": ["keyword.operator.ternary.zap"],
      "settings": { "foreground": "#d4d4d4" }
    },
    {
      "name": "HTTP methods (get post put delete patch) — green like keywords",
      "scope": ["keyword.other.http-method.zap"],
      "settings": { "foreground": "#4ec9b0", "fontStyle": "bold" }
    },
    {
      "name": "Server / on keywords",
      "scope": ["keyword.other.server.zap"],
      "settings": { "foreground": "#569cd6", "fontStyle": "bold" }
    },
    {
      "name": "Route strings",
      "scope": ["string.quoted.route.zap"],
      "settings": { "foreground": "#ce9178", "fontStyle": "underline" }
    },
    {
      "name": "Object properties / member access",
      "scope": ["variable.other.property.zap", "support.variable.property.zap"],
      "settings": { "foreground": "#9cdcfe" }
    }
  ]
}
