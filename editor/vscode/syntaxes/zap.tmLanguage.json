{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Zap",
  "scopeName": "source.zap",
  "patterns": [
    { "include": "#comments" },
    { "include": "#template-strings" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords-control" },
    { "include": "#keywords-declaration" },
    { "include": "#constants" },
    { "include": "#function-def" },
    { "include": "#function-call" },
    { "include": "#builtins" },
    { "include": "#server-block" },
    { "include": "#operators" },
    { "include": "#identifiers" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.zap",
          "match": "//.*$"
        },
        {
          "name": "comment.block.zap",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": { "name": "punctuation.definition.comment.zap" }
          }
        }
      ]
    },

    "template-strings": {
      "name": "string.template.zap",
      "begin": "`",
      "end": "`",
      "patterns": [
        {
          "name": "meta.template.expression.zap",
          "begin": "\\{",
          "end": "\\}",
          "beginCaptures": { "0": { "name": "punctuation.definition.template-expression.begin.zap" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.template-expression.end.zap" } },
          "patterns": [{ "include": "$self" }]
        },
        {
          "name": "constant.character.escape.zap",
          "match": "\\\\[\\\\`nrt]"
        }
      ]
    },

    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.zap",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.zap", "match": "\\\\[\\\\\"nrt]" }
          ]
        },
        {
          "name": "string.quoted.single.zap",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.zap", "match": "\\\\[\\\\\'nrt]" }
          ]
        }
      ]
    },

    "numbers": {
      "patterns": [
        { "name": "constant.numeric.float.zap",   "match": "\\b[0-9]+\\.[0-9]+\\b" },
        { "name": "constant.numeric.hex.zap",     "match": "\\b0x[0-9a-fA-F]+\\b" },
        { "name": "constant.numeric.integer.zap", "match": "\\b[0-9]+\\b" }
      ]
    },

    "keywords-control": {
      "name": "keyword.control.zap",
      "match": "\\b(if|else|while|loop|from|to|step|return|break|continue|try|catch|finally)\\b"
    },

    "keywords-declaration": {
      "patterns": [
        { "name": "storage.type.zap",     "match": "\\b(let|fn|import|export|as)\\b" },
        { "name": "keyword.other.zap",    "match": "\\b(server|on|get|post|put|delete|patch)\\b" }
      ]
    },

    "constants": {
      "patterns": [
        { "name": "constant.language.boolean.zap", "match": "\\b(true|false)\\b" },
        { "name": "constant.language.null.zap",    "match": "\\b(null)\\b" }
      ]
    },

    "function-def": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
          "captures": {
            "1": { "name": "storage.type.function.zap" },
            "2": { "name": "entity.name.function.zap" }
          }
        }
      ]
    },

    "function-call": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*\\(",
      "captures": {
        "1": { "name": "entity.name.function.call.zap" }
      }
    },

    "builtins": {
      "name": "support.function.builtin.zap",
      "match": "\\b(print|println|len|type|json|parse|keys|values|entries|range|push|pop|shift|unshift|join|split|includes|indexOf|slice|reverse|sort|flat|map|filter|reduce|find|every|some|upper|lower|trim|replace|startsWith|endsWith|repeat|padStart|toNumber|toInt|toStr|toBool|abs|ceil|floor|round|sqrt|pow|min|max|random|randomInt|now|date|sleep|exit|env)\\b"
    },

    "server-block": {
      "patterns": [
        {
          "match": "\\b(server)\\s+(on)\\s+([0-9]+)",
          "captures": {
            "1": { "name": "keyword.other.server.zap" },
            "2": { "name": "keyword.other.on.zap" },
            "3": { "name": "constant.numeric.port.zap" }
          }
        },
        {
          "match": "\\b(get|post|put|delete|patch)\\s+(\"[^\"]+\")",
          "captures": {
            "1": { "name": "keyword.other.http-method.zap" },
            "2": { "name": "string.quoted.route.zap" }
          }
        }
      ]
    },

    "operators": {
      "patterns": [
        { "name": "keyword.operator.arrow.zap",       "match": "->" },
        { "name": "keyword.operator.comparison.zap",  "match": "==|!=|<=|>=" },
        { "name": "keyword.operator.logical.zap",     "match": "&&|\\|\\||!" },
        { "name": "keyword.operator.assignment.zap",  "match": "\\+=|-=|\\*=|/=|=" },
        { "name": "keyword.operator.increment.zap",   "match": "\\+\\+|--" },
        { "name": "keyword.operator.power.zap",       "match": "\\*\\*" },
        { "name": "keyword.operator.arithmetic.zap",  "match": "[+\\-*/%]" },
        { "name": "keyword.operator.ternary.zap",     "match": "\\?|:" }
      ]
    },

    "identifiers": {
      "name": "variable.other.zap",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    }
  }
}
